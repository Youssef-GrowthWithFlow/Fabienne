# Copy to .env on the VPS at /opt/fabienne/<env>/.env
# Never commit the real .env — it lives only on the VPS (and as GitHub secrets).

# PostgreSQL (internal to the compose project, no host port exposed)
POSTGRES_USER=fabienne
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=fabienne_db
DATABASE_URL=postgresql+asyncpg://fabienne:__CHANGE_ME__@db:5432/fabienne_db

# App
ENVIRONMENT=production
SECRET_KEY=__CHANGE_ME_64_CHARS__
CORS_ORIGINS=https://fabienne.growthwithflow.com

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Enrichment
GOOGLE_PLACES_API_KEY=
DROPCONTACT_API_KEY=

# SMTP (transactional email — Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=true
SMTP_USE_TLS=false
