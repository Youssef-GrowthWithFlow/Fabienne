# Copy to .env on the VPS at /opt/fabienne/<env>/.env
# Never commit the real .env — it lives only on the VPS (and as GitHub secrets).

# PostgreSQL (internal to the compose project, no host port exposed)
POSTGRES_USER=fabienne
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=fabienne_db
DATABASE_URL=postgresql+asyncpg://fabienne:__CHANGE_ME__@db:5432/fabienne_db

# App
ENVIRONMENT=production
SECRET_KEY=__CHANGE_ME_64_CHARS__
CORS_ORIGINS=https://fabienne.growthwithflow.com

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Enrichment
GOOGLE_PLACES_API_KEY=
DROPCONTACT_API_KEY=

# SMTP (transactional email — Gmail Workspace via mot de passe d'application)
# SMTP_PASSWORD = les 16 caractères de myaccount.google.com/apppasswords,
# espaces retirés. Jamais le mot de passe du compte.
# Laisser SMTP_HOST vide désactive l'envoi (le lien est loggué à la place).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youssef@growthwithflow.com
SMTP_PASSWORD=__APP_PASSWORD_16_CHARS__
SMTP_FROM=Youssef @ Growth With Flow <youssef@growthwithflow.com>
SMTP_USE_SSL=true

# Où atterrit l'utilisateur en cliquant le lien de reset
FRONTEND_URL=https://fabienne.growthwithflow.com
