# PostgreSQL
POSTGRES_USER=fabienne
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fabienne_db
DATABASE_URL=postgresql+asyncpg://fabienne:changeme@db:5432/fabienne_db

# App
ENVIRONMENT=development
SECRET_KEY=change-this-in-production
CORS_ORIGINS=http://localhost:5173

# Gemini (Google AI Studio) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Google Places API (New) — enrichment with phone, hours, GPS, rating, reviews.
# Get a key at https://console.cloud.google.com/google/maps-apis (enable
# "Places API (New)"). Leave empty to disable Places enrichment.
GOOGLE_PLACES_API_KEY=

# DropContact — B2B contact enrichment (email, phone, LinkedIn, job title)
# triggered on candidate validation. https://www.dropcontact.com/
# Leave empty to disable.
DROPCONTACT_API_KEY=
